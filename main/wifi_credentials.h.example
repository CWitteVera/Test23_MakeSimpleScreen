/*
 * wifi_credentials.h.example
 *
 * HOW TO USE
 * ----------
 * 1. Copy this file to  main/wifi_credentials.h
 *        cp main/wifi_credentials.h.example main/wifi_credentials.h
 *
 * 2. Replace the placeholder strings below with your actual WiFi credentials.
 *
 * 3. The file main/wifi_credentials.h is listed in .gitignore, so your
 *    credentials will never be committed to the repository.
 *
 * NOTE: Do NOT edit this .example file directly – it is committed to the repo
 * as documentation only and should contain only placeholder values.
 */

#pragma once

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"
