/*
 * wifi_credentials.h.example
 *
 * WiFi credentials are now configured via the ESP-IDF Kconfig system.
 *
 * HOW TO SET YOUR CREDENTIALS
 * ---------------------------
 * Option A (recommended): Use idf.py menuconfig
 *     idf.py menuconfig
 *     → Example Configuration → Network / MQTT
 *     → Set "WiFi SSID" and "WiFi Password"
 *
 *     This writes the values to sdkconfig, which is git-ignored, so your
 *     credentials will never be committed to the repository.
 *
 * Option B: Add directly to a local sdkconfig (also git-ignored):
 *     CONFIG_MQTT_WIFI_SSID="your-wifi-ssid"
 *     CONFIG_MQTT_WIFI_PASSWORD="your-wifi-password"
 *
 * NOTE: This file is kept as documentation only.  It is no longer included
 * by the build system.  Do NOT create a wifi_credentials.h from this template.
 */
